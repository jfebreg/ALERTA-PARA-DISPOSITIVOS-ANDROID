{
  "entities": {
    "Enrolado": {
      "title": "Enrolado",
      "description": "User or Admin registered in the alarm system",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "User's unique ID/Auth UID" },
        "nombre": { "type": "string", "description": "Visual identification name" },
        "telefono": { "type": "string", "description": "Phone number for SMS dispatch" },
        "rol": { "type": "string", "enum": ["ADMIN", "USER"], "description": "System role" },
        "activo": { "type": "boolean", "description": "Status to participate in notifications" },
        "creadoEn": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "ultimaSync": { "type": "string", "format": "date-time", "description": "Last synchronization timestamp" }
      },
      "required": ["id", "nombre", "telefono", "rol", "activo"]
    },
    "Pin": {
      "title": "Pin",
      "description": "Enrollment PIN generated by Admin for new user registration",
      "type": "object",
      "properties": {
        "pin": { "type": "string", "description": "Unique 6-digit numeric PIN" },
        "nombreDestino": { "type": "string", "description": "Target user's name" },
        "usada": { "type": "boolean", "description": "Whether this PIN has been consumed" },
        "creadoPor": { "type": "string", "description": "Admin UID who created the PIN" },
        "creadoEn": { "type": "string", "format": "date-time", "description": "Generation timestamp" },
        "expiraEn": { "type": "string", "format": "date-time", "description": "Expiration timestamp" },
        "usadaPor": { "type": "string", "description": "Consumed user UID" }
      },
      "required": ["pin", "nombreDestino", "usada", "creadoPor", "creadoEn", "expiraEn"]
    },
    "Config": {
      "title": "Config",
      "description": "Singleton configuration values for the system",
      "type": "object",
      "properties": {
        "mensajePredefinido": { "type": "string", "description": "Fallback text shown on alarm sirens" },
        "palabraClave": { "type": "string", "description": "Trigger word contained in SMS to recognize alarms" },
        "pinTtlHoras": { "type": "integer", "description": "TTL hours for generated PIN codes" }
      },
      "required": ["mensajePredefinido", "palabraClave", "pinTtlHoras"]
    },
    "Alarma": {
      "title": "Alarma",
      "description": "Metadata for alarm events synchronized to the server",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique alarm record ID" },
        "emisorId": { "type": "string", "description": "Sender User UID" },
        "emisorNombre": { "type": "string", "description": "Sender identification name string" },
        "mensaje": { "type": "string", "description": "Payload sent via SMS" },
        "enviadaEn": { "type": "string", "format": "date-time", "description": "Dispatch timestamp" },
        "confirmaciones": { "type": "object", "description": "Map of user ID -> completion timestamp for receiver acknowledgements" }
      },
      "required": ["id", "emisorId", "emisorNombre", "mensaje", "enviadaEn"]
    }
  },
  "firestore": {
    "/enrolados/{userId}": {
      "schema": "Enrolado",
      "description": "Authorized phone ledger and identities"
    },
    "/pines/{pinId}": {
      "schema": "Pin",
      "description": "Hashed or plain-text OTP enrollment PIN records"
    },
    "/config/singleton": {
      "schema": "Config",
      "description": "General system setup metadata"
    },
    "/alarmas/{alarmaId}": {
      "schema": "Alarma",
      "description": "System event tracking history ledger"
    }
  }
}
